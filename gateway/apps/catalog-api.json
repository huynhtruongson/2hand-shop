{
    "name": "Catalog API",
    "api_id": "catalog-api",
    "org_id": "default",
    "definition": {
        "location": "header",
        "key": "version"
    },
    "use_keyless": true,
    "version_data": {
        "not_versioned": true,
        "versions": {
            "Default": {
                "name": "Default"
            }
        }
    },
    "proxy": {
        "listen_path": "/api/v1/catalog",
        "target_url": "http://catalog-service:8082",
        "strip_listen_path": true
    },
    "cors": {
        "enable": true,
        "allowed_origins": ["http://localhost:3000"],
        "allowed_methods": ["GET","POST","PUT","DELETE","OPTIONS"],
        "allowed_headers": [
            "Authorization",
            "Content-Type",
            "X-Request-ID"
        ],
        "exposed_headers": ["X-Request-ID"],
        "allow_credentials": true,
        "options_passthrough": false
    }
}
